# ============================================================
# PRODUCTION ENV — .env.prod olarak kopyala, değerleri doldur
# ============================================================

# Django
SECRET_KEY=en-az-50-karakter-rastgele-anahtar-buraya
APP_ENV=prod
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.prod
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
GUNICORN_WORKERS=3

# Veritabanı (PostgreSQL)
DB_NAME=iuc_staj_db
DB_USER=iuc_staj_user
DB_PASSWORD=guclu-rastgele-sifre
DB_HOST=db
DB_PORT=5432
USE_SQLITE=False

# Redis
REDIS_PASSWORD=guclu-redis-sifresi
REDIS_URL=redis://:guclu-redis-sifresi@redis:6379/0

# Frontend / CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# NextAuth (frontend)
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=openssl-rand-base64-32-ile-uret

# Google OAuth (opsiyonel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# E-posta
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=gmail-uygulama-sifresi
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Dosya Depolama — Cloudflare R2 (production)
CV_STORAGE_BACKEND=r2
R2_ACCOUNT_ID=cloudflare-account-id
R2_ACCESS_KEY_ID=r2-access-key
R2_SECRET_ACCESS_KEY=r2-secret-key
R2_BUCKET_NAME=iuc-staj-cvs
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
